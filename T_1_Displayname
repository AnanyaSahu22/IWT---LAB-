<!DOCTYPE html>
<html>
<body>

Enter Name:
<input type="text" id="name">

<button onclick="display()">Show</button>

<p id="output"></p>

<script>

function display(){

let name = document.getElementById("name").value;

document.getElementById("output").innerHTML =
"Hello " + name;

}

</script>

</body>
</html>
